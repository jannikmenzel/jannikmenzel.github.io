---
import Layout from "../layouts/Layout.astro";

const title = "Impressum";
---

<Layout
    title={title}
    description="Impressum von Jannik Menzel: Angaben gemäß § 5 TMG, Kontaktinformationen und rechtliche Hinweise."
    keywords="Impressum, Kontakt, Rechtliches, Jannik Menzel, TMG, Website"
    og={{
        title: "Impressum – Jannik Menzel",
        description:
            "Impressum von Jannik Menzel: Angaben gemäß § 5 TMG, Kontaktinformationen und rechtliche Hinweise.",
        url: "https://jannikmenzel.me/impressum",
        image: "https://jannikmenzel.me/social-preview.png",
    }}
    twitter={{
        title: "Impressum – Jannik Menzel",
        description:
            "Impressum von Jannik Menzel: Angaben gemäß § 5 TMG, Kontaktinformationen und rechtliche Hinweise.",
        image: "https://jannikmenzel.me/social-preview.png",
    }}
    canonical="https://jannikmenzel.me/impressum"
>
    <main class="w-full container px-4 sm:px-16 mb-22" style="max-width: 1100px;">
        <!-- Header -->
        <header class="pt-20">
            <h1 class="text-center text-4xl sm:text-5xl font-bold font-display mb-4">Impressum</h1>
            <div class="h-1 w-24 bg-primary mx-auto"></div>
        </header>

        <!-- Content -->
        <section class="mb-6 sm:mb-6 pt-22">
            <h2 class="text-xl sm:text-2xl font-medium mb-2">Betreiber</h2>
            <p class="font-thin">Jannik Menzel</p>
        </section>

        <section class="mb-6 sm:mb-6">
            <h2 class="text-xl sm:text-2xl font-medium mb-2">Anschrift</h2>
            <address class="font-thin not-italic">
                <span id="address-obfuscated"></span>
            </address>
        </section>

        <section class="mb-6 sm:mb-6">
            <h2 class="text-xl sm:text-2xl font-medium mb-2">Kontakt</h2>
            <p class="font-thin">
                E‑Mail:
                <span id="email-obfuscated"></span>
            </p>
            <p class="font-thin">
                Internet: <a
                    href="https://jannikmenzel.me"
                    class="text-primary underline"
                    target="_blank"
                    rel="noopener">jannikmenzel.me</a
                >
            </p>
        </section>

        <section class="text-xs sm:text-sm text-lightOff">
            <p>
                Bei Fragen zum Impressum nutzen Sie bitte das Kontaktformular auf der Webseite oder
                schreiben Sie eine E‑Mail an die oben genannte Adresse.
            </p>
        </section>

        <script is:inline>
            // E-Mail Obfuscation
            const emailUser = "jnk.menzel";
            const emailDomain = "gmail.com";
            const email = emailUser + "@" + emailDomain;
            const emailSpan = document.getElementById("email-obfuscated");
            if (emailSpan) {
                emailSpan.innerHTML = `<a href="mailto:${email}" class="text-primary underline">${emailUser}&#64;${emailDomain}</a>`;
            }

            // Address Obfuscation
            const addressParts = [
                "Zellescher Weg ",
                "41d",
                "<br />01217 ",
                "Dresden",
                "<br />Deutschland",
            ];
            const addressSpan = document.getElementById("address-obfuscated");
            if (addressSpan) {
                addressSpan.innerHTML = addressParts.join("");
            }
        </script>
    </main>
</Layout>
