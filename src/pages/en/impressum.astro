---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../i18n/ui";

const lang = "en";
---

<Layout
    title={t(lang, "impressum.title")}
    lang="en"
    description="Imprint of Jannik Menzel: Information according to § 5 TMG, contact information and legal notices."
    keywords="Imprint, Contact, Legal, Jannik Menzel, TMG, Website"
    og={{
        title: `${t(lang, "impressum.title")} – Jannik Menzel`,
        description:
            "Imprint of Jannik Menzel: Information according to § 5 TMG, contact information and legal notices.",
        url: "https://jannikmenzel.me/en/impressum/",
        image: "https://jannikmenzel.me/social-preview.png",
    }}
    twitter={{
        title: "Legal Notice – Jannik Menzel",
        description: "Legal notice of the website of Jannik Menzel.",
        image: "https://jannikmenzel.me/social-preview.png",
    }}
    canonical="https://jannikmenzel.me/en/impressum/"
>
    <main class="w-full container px-4 sm:px-16 mb-22" style="max-width: 1100px;">
        <!-- Header -->
        <header class="pt-20">
            <h1 class="text-center text-4xl sm:text-5xl font-bold font-display mb-4">
                {t(lang, "impressum.title")}
            </h1>
            <div class="h-1 w-24 bg-primary mx-auto"></div>
        </header>

        <!-- Content -->
        <section class="mb-6 sm:mb-6 pt-22">
            <h2 class="text-xl sm:text-2xl font-medium mb-2">{t(lang, "impressum.operator")}</h2>
            <p class="font-thin">Jannik Menzel</p>
        </section>

        <section class="mb-6 sm:mb-6">
            <h2 class="text-xl sm:text-2xl font-medium mb-2">{t(lang, "impressum.address")}</h2>
            <address class="font-thin not-italic">
                <span id="address-obfuscated"></span>
            </address>
        </section>

        <section class="mb-6 sm:mb-6">
            <h2 class="text-xl sm:text-2xl font-medium mb-2">{t(lang, "impressum.contact")}</h2>
            <p class="font-thin">
                {t(lang, "impressum.email")}
                <span id="email-obfuscated"></span>
            </p>
            <p class="font-thin">
                {t(lang, "impressum.website")}
                <a
                    href="https://jannikmenzel.me"
                    class="text-primary underline"
                    target="_blank"
                    rel="noopener">jannikmenzel.me</a
                >
            </p>
        </section>

        <section class="text-xs sm:text-sm text-lightOff">
            <p>
                {t(lang, "impressum.footerNote")}
            </p>
        </section>

        <script is:inline>
            // E-Mail Obfuscation
            const emailUser = "contact";
            const emailDomain = "jannikmenzel.me";
            const email = emailUser + "@" + emailDomain;
            const emailSpan = document.getElementById("email-obfuscated");
            if (emailSpan) {
                emailSpan.innerHTML = `<a href="mailto:${email}" class="text-primary underline">${emailUser}&#64;${emailDomain}</a>`;
            }

            // Address Obfuscation
            const addressParts = [
                "Zellescher Weg ",
                "41d",
                "<br />01217 ",
                "Dresden",
                "<br />Deutschland",
            ];
            const addressSpan = document.getElementById("address-obfuscated");
            if (addressSpan) {
                addressSpan.innerHTML = addressParts.join("");
            }
        </script>
    </main>
</Layout>
