---
import Hero from "../components/home/Hero.astro";
import Layout from "../layouts/Layout.astro";
import Carousel from "../components/home/Carousel.astro";
import Projects from "../components/home/Projects.astro";
import Services from "../components/home/Services.astro";
import Contact from "../components/home/Contact.astro";
import { t } from "../i18n/ui";

const lang = "de";

const title = t(lang, "hero.title").replace("<br />", " & ");
const description = t(lang, "hero.description");
---

<Layout
    title={`${title} - Portfolio & Blog`}
    description={description}
    lang="de"
    keywords="Jannik Menzel, Portfolio, Informatik, Dresden, Webentwicklung, Projekte, Blog"
    og={{
        title: `${title} - Portfolio & Blog`,
        description: description,
        url: "https://jannikmenzel.me",
        image: "https://jannikmenzel.me/social-preview.png",
    }}
    twitter={{
        title: `${title} - Portfolio & Blog`,
        description: description,
        image: "https://jannikmenzel.me/social-preview.png",
    }}
    canonical="https://jannikmenzel.me"
    structuredData={{
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Jannik Menzel",
        url: "https://jannikmenzel.me",
    }}
>
    <Hero />
    <Carousel />
    <Projects />
    <Services />
    <Contact />
</Layout>
