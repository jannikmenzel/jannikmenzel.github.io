---
import Layout from "../layouts/Layout.astro";
import { getLangFromUrl, t } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
---

<Layout
    title={t(lang, "404.title")}
    description={t(lang, "404.description")}
    keywords="404, Page not found, Error, Jannik Menzel, Portfolio"
    og={{
        title: `404 – ${t(lang, "404.title")}`,
        description: t(lang, "404.description"),
        url: "https://jannikmenzel.me/en/404",
        image: "https://jannikmenzel.me/social-preview.png",
    }}
    twitter={{
        title: `404 – ${t(lang, "404.title")}`,
        description: t(lang, "404.description"),
        image: "https://jannikmenzel.me/social-preview.png",
    }}
    canonical="https://jannikmenzel.me/en/404"
>
    <section class="flex flex-col items-center justify-center min-h-[80vh] text-center py-16">
        <h1 class="text-8xl font-bold mb-4">404</h1>
        <h2 class="text-2xl font-semibold mb-2">{t(lang, "404.title")}</h2>
        <p class="mb-8 text-lg text-muted-foreground">
            {t(lang, "404.description")}
        </p>
        <a href={lang === "en" ? "/en" : "/"} class="btn btn-primary">{t(lang, "404.backToHome")}</a
        >
    </section>
</Layout>
