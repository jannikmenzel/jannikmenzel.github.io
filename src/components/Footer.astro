---
import { Image } from "astro:assets";
import instagramIcon from "../images/icons/instagram.svg";
import linkedinIcon from "../images/icons/linkedin.svg";
import githubIcon from "../images/icons/github.svg";
import { getLangFromUrl, t, getLocalizedPath, defaultLang, type Lang } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);

function localizedHref(href: string): string {
    return getLocalizedPath(lang, href);
}

const otherLang: Lang = lang === defaultLang ? "en" : "de";
---

<footer
    class="bg-darkAlt dark:bg-darkOff px-6 sm:px-8 py-10 sm:py-20 text-sm sm:text-base"
    role="contentinfo"
>
    <ul class="flex flex-wrap justify-center gap-4 sm:gap-10 list-none text-center">
        <li>
            <a
                href={localizedHref("/")}
                class="text-light text-sm sm:text-base hover:text-lightOff hover:underline"
                >{t(lang, "nav.home")}</a
            >
        </li>
        <li>
            <a
                href={localizedHref("/blog/")}
                class="text-light text-sm sm:text-base hover:text-lightOff hover:underline"
                >{t(lang, "nav.blog")}</a
            >
        </li>
        <li>
            <a
                href={localizedHref("/impressum/")}
                class="text-light text-sm sm:text-base hover:text-lightOff hover:underline"
            >
                {t(lang, "nav.impressum")}
            </a>
        </li>
        <li>
            <a
                href={localizedHref("/datenschutz/")}
                class="text-light text-sm sm:text-base hover:text-lightOff hover:underline"
            >
                {t(lang, "nav.datenschutz")}
            </a>
        </li>
    </ul>
    <div class="flex justify-center gap-6 my-8 sm:my-10">
        <a
            href="https://instagram.com/jnk.mnz"
            target="_blank"
            rel="noopener noreferrer"
            class="text-light"
            aria-label="Instagram"
        >
            <Image src={instagramIcon} alt="" class="h-10 w-10 sm:h-12 sm:w-12 mx-auto" />
        </a>
        <a
            href="https://linkedin.com/in/jannik-menzel"
            target="_blank"
            rel="noopener noreferrer"
            class="text-light"
            aria-label="LinkedIn"
        >
            <Image src={linkedinIcon} alt="" class="h-10 w-10 sm:h-12 sm:w-12 mx-auto" />
        </a>
        <a
            href="https://github.com/jannikmenzel"
            target="_blank"
            rel="noopener noreferrer"
            class="text-light"
            aria-label="GitHub"
        >
            <Image src={githubIcon} alt="" class="h-10 w-10 sm:h-12 sm:w-12 mx-auto" />
        </a>
    </div>
    <p class="text-lightOff text-center text-sm sm:text-base">
        &copy; Copyright {" "}
        <a href={localizedHref("/")} class="text-light text-sm sm:text-base"> Jannik Menzel </a>{
            " "
        }
        | {t(lang, "footer.copyright")} |
        <a
            href={getLocalizedPath(otherLang, Astro.url.pathname)}
            class="text-light text-sm sm:text-base hover:text-lightOff hover:underline"
            onclick={`localStorage.setItem('language', '${otherLang}')`}
        >
            {t(lang, "footer.switchTo")}
            {otherLang === "en" ? "English" : "Deutsch"}
        </a>
    </p>
</footer>
