---
import { getLangFromUrl, t } from "../../i18n/ui";

const lang = getLangFromUrl(Astro.url);
---

<section id="contact" class="py-32 px-6 bg-backgroundAlt">
    <div class="container">
        <div class="max-w-7xl mx-auto mb-24">
            <h2
                class="font-headline text-4xl sm:text-5xl font-black tracking-tighter text-primary mb-4 uppercase"
            >
                {t(lang, "contact.title")}
            </h2>
            <div class="h-1 w-24 bg-primary"></div>
        </div>

        <form
            id="contact-form"
            class="max-w-4xl mx-auto bg-background px-2 py-8 sm:px-8 space-y-6 scrolling-section"
            action="https://api.web3forms.com/submit"
            method="POST"
            data-sending={t(lang, "contact.sending")}
            data-error-prefix={t(lang, "contact.errorPrefix")}
            data-error-generic={t(lang, "contact.errorGeneric")}
            data-success={t(lang, "contact.success")}
        >
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="group">
                    <label
                        for="name"
                        class="font-label text-[0.9rem] uppercase tracking-widest mb-2 block"
                        >{t(lang, "contact.name")}</label
                    >
                    <input
                        id="name"
                        name="name"
                        type="text"
                        required
                        aria-required="true"
                        placeholder={t(lang, "contact.placeholder.name")}
                        class="w-full bg-backgroundAlt border-[0.5px] border-zinc-700/10 rounded-none px-4 py-3 font-body text-sm placeholder:text-muted-foreground/60 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                    />
                </div>

                <div class="group">
                    <label
                        for="email"
                        class="font-label text-[0.9rem] uppercase tracking-widest mb-2 block"
                        >{t(lang, "contact.email")}</label
                    >
                    <input
                        id="email"
                        name="email"
                        type="email"
                        required
                        aria-required="true"
                        placeholder={t(lang, "contact.placeholder.email")}
                        class="w-full bg-backgroundAlt border-[0.5px] border-zinc-700/10 rounded-none px-4 py-3 font-body text-sm placeholder:text-muted-foreground/60 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                    />
                </div>
            </div>

            <div class="group">
                <label
                    for="subject"
                    class="font-label text-[0.9rem] uppercase tracking-widest mb-2 block"
                    >{t(lang, "contact.subject")}</label
                >
                <input
                    id="subject"
                    name="subject"
                    type="text"
                    required
                    aria-required="true"
                    placeholder={t(lang, "contact.placeholder.subject")}
                    class="w-full bg-backgroundAlt border-[0.5px] border-zinc-700/10 rounded-none px-4 py-3 font-body text-sm placeholder:text-muted-foreground/60 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
                />
            </div>

            <div class="group">
                <label
                    for="message"
                    class="font-label text-[0.9rem] uppercase tracking-widest mb-2 block"
                    >{t(lang, "contact.message")}</label
                >
                <textarea
                    id="message"
                    name="message"
                    required
                    aria-required="true"
                    placeholder={t(lang, "contact.placeholder.message")}
                    rows="5"
                    class="w-full bg-backgroundAlt border-[0.5px] border-zinc-700/10 rounded-none px-4 py-3 font-body text-sm placeholder:text-muted-foreground/60 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary resize-none"
                ></textarea>
            </div>

            <input type="hidden" name="access_key" value="bb6bd7c6-94b3-40e3-8bba-682f0227bd74" />

            <div
                class="absolute left-[-9999px] top-auto h-0 w-0 overflow-hidden"
                aria-hidden="true"
            >
                <label for="website">Website</label>
                <input
                    id="website"
                    name="_gotcha"
                    type="text"
                    autocomplete="off"
                    tabindex="-1"
                    spellcheck="false"
                />
            </div>

            <div class="flex items-center justify-between gap-4">
                <button class="btn btn-primary" type="submit"> {t(lang, "contact.submit")} </button>
                <div id="form-success" class="text-sm font-thin hidden">
                    {t(lang, "contact.success")}
                </div>
            </div>
        </form>

        <script>
            const messageField = document.getElementById("message");
            const form = document.getElementById("contact-form") as HTMLFormElement | null;
            const submitBtn = form?.querySelector(
                'button[type="submit"]'
            ) as HTMLButtonElement | null;
            const successMsg = document.getElementById("form-success");
            const honeypotField = document.getElementById("website") as HTMLInputElement | null;

            if (messageField) {
                messageField.addEventListener("input", () => {
                    messageField.style.height = "auto";
                    messageField.style.height = messageField.scrollHeight + "px";
                });
            }

            if (form && submitBtn && successMsg) {
                const sendingText = form.getAttribute("data-sending") || "Sending...";
                const errorPrefix = form.getAttribute("data-error-prefix") || "Error: ";
                const errorGeneric =
                    form.getAttribute("data-error-generic") ||
                    "Something went wrong. Please try again.";

                const showMessage = (text: string) => {
                    successMsg.textContent = text;
                    successMsg.classList.remove("hidden");
                    setTimeout(() => {
                        successMsg.classList.add("hidden");
                    }, 5000);
                };

                form.addEventListener("submit", async (e) => {
                    e.preventDefault();

                    if (honeypotField && honeypotField.value.trim()) {
                        return;
                    }

                    const formData = new FormData(form);

                    const originalText = submitBtn.textContent;

                    submitBtn.textContent = sendingText;
                    submitBtn.disabled = true;

                    try {
                        const response = await fetch("https://api.web3forms.com/submit", {
                            method: "POST",
                            body: formData,
                        });

                        const data = await response.json();

                        if (response.ok) {
                            form.reset();
                            showMessage(form.getAttribute("data-success") || "Thank you!");
                        } else {
                            showMessage(errorPrefix + data.message);
                        }
                    } catch {
                        showMessage(errorGeneric);
                    } finally {
                        submitBtn.textContent = originalText;
                        submitBtn.disabled = false;
                    }
                });
            }
        </script>
    </div>
</section>
