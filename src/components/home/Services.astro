---
import { Code, PanelsTopLeft, Database, PenTool, Target, Zap } from "@lucide/astro";
import { getLangFromUrl, t } from "../../i18n/ui";

const lang = getLangFromUrl(Astro.url);

const services = [
    { icon: Code, key: "frontend" },
    { icon: PenTool, key: "uiux" },
    { icon: PanelsTopLeft, key: "wordpress" },
    { icon: Database, key: "ssg" },
    { icon: Target, key: "brand" },
    { icon: Zap, key: "performance" },
];
---

<!-- Services Section -->
<section class="py-24 px-6">
    <div class="container px-4 mx-auto">
        <div class="max-w-7xl mx-auto mb-24">
            <h2
                class="font-headline text-4xl sm:text-5xl font-black tracking-tighter text-primary mb-4 uppercase"
            >
                {t(lang, "services.title")}
            </h2>
            <div class="h-1 w-24 bg-primary"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 scrolling-section">
            {
                services.map((service) => (
                    <div class="card flex flex-col items-center justify-center bg-backgroundAlt p-6 h-64 text-center space-y-4">
                        <service.icon class="w-12 h-12 text-primary mx-auto" />
                        <h3 class="text-xl font-semibold">
                            {t(lang, `services.items.${service.key}.title`)}
                        </h3>
                        <p class="font-thin">
                            {t(lang, `services.items.${service.key}.description`)}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
